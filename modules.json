    {
      "index": 8,
      "name": "Tanıtım Modülü",
      "path": "module-1",
      "local": "body",
      "category": "module",
      "desing": {
        "name": {
          "tr": "Family Şirketi'ni Tanıyın",
          "en": "Get to Know the Family Company",
          "ar": "تعرف على الشركة العائلية"
        },
        "name2": {
          "tr": "Vizyonumuz",
          "en": "Our Vision",
          "ar": "رؤيتنا"
        },
        "spot2": {
          "tr": "Kozmetik ve inşaat sektörlerinde ulusal ve uluslararası pazarda daha geniş kitlelere ulaşarak, müşteri beklentilerini en iyi şekilde karşılamak.",
          "en": "To meet customer expectations in the best way by reaching wider audiences in the national and international markets in the cosmetics and construction sectors.",
          "ar": "تلبية توقعات العملاء بأفضل طريقة من خلال الوصول إلى جمهور أوسع في الأسواق الوطنية والدولية في قطاعي مستحضرات التجميل والبناء."
        },
        "icon2": "home",
        "name3": {
          "tr": "Misyonumuz",
          "en": "Our mission",
          "ar": "مهمتنا"
        },
        "spot3": {
          "tr": "Müşterilerimize en kaliteli ürünleri sunmak, onların beklentilerini aşmak ve sektördeki lider konumumuzu pekiştirmek.",
          "en": "To offer the best quality products to our customers, to exceed their expectations and to reinforce our leading position in the industry.",
          "ar": "تقديم أفضل المنتجات عالية الجودة لعملائنا، لتجاوز توقعاتهم وتعزيز مكانتنا الرائدة في الصناعة."
        },
        "icon3": "home",
        "img": "bg.jpg",
        "bgcolor": "#601515",
        "fontcolor": "#fff",
        "margintop": "20",
        "marginbotton": "20",
        "description": {
          "tr": "Company olarak 25 yıldır profesyonel personel kadromuz ile ithalat, ihracat, danışmanlık, lojistik ve transit ticaret alanlarında hizmet sunmaktan onur duyuyoruz. Ürünü olsun ya da olmasın, tüm firmalar için profesyonel ve kurumsal danışmanlık hizmeti sunarak firmaların etkin şekilde ithalat ya da ihracat yapmalarını sağlıyoruz.",
          "en": "",
          "ar": ""
        }
      },
